{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CMake: Configure Build",
      "type": "shell",
      "command": "cmake",
      "args": [
        "-S", "${workspaceFolder}/Examples/Sandbox",            // Source directory
        "-B", "${workspaceFolder}/Examples/Sandbox/build",      // Build directory
        "-DCMAKE_BUILD_TYPE=Debug",            // Optional: build type
      ],
      "problemMatcher": ["$gcc"],             // Adjust if using MSVC
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": true
      }
    },
    {
      "label": "k3s: ssh-readyup-nodes",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "make -C \"${workspaceFolder}/k8s/k3s\" ssh-setup && make -C \"${workspaceFolder}/k8s/k3s\" sudo-setup && make -C \"${workspaceFolder}/k8s/k3s\" dependency-setup"
      ],
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "showReuseMessage": true,
        "clear": false
      }
    }
  ]
}
